<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.skinsmart.ui.fragments.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.skinsmart.ui.fragments.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.skinsmart.ui.fragments.HomeFragment"
        android:label="Home - Feed"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_smartShelfFragment"
            app:destination="@id/smartShelfFragment" />
        <action
            android:id="@+id/action_homeFragment_to_createPostFragment"
            app:destination="@id/createPostFragment" />
    </fragment>

    <fragment
        android:id="@+id/smartShelfFragment"
        android:name="com.example.skinsmart.ui.fragments.SmartShelfFragment"
        android:label="Smart Shelf"
        tools:layout="@layout/fragment_smart_shelf" />
        
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.skinsmart.ui.fragments.SearchFragment"
        android:label="Discover"
        tools:layout="@layout/fragment_search" />
        
    <fragment
        android:id="@+id/createPostFragment"
        android:name="com.example.skinsmart.ui.fragments.CreatePostFragment"
        android:label="Write Review"
        tools:layout="@layout/fragment_create_post" />
        
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.skinsmart.ui.fragments.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />
        
</navigation>
