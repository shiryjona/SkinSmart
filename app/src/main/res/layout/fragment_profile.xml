<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f9fafb">

    <!-- Profile Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:background="@android:color/white">

        <ImageView
            android:id="@+id/ivProfileImage"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111827"/>

        <TextView
            android:id="@+id/tvUserSkinType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skin Type: Loading..."
            android:textColor="#ea580c"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnEditProfile"
                android:layout_width="130dp"
                android:layout_height="40dp"
                android:text="Edit Profile"
                android:textSize="12sp"
                android:backgroundTint="#f3f4f6"
                android:textColor="#4b5563"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="100dp"
                android:layout_height="40dp"
                android:text="Log Out"
                android:textSize="12sp"
                android:backgroundTint="#ef4444"
                android:textColor="#ffffff"/>

        </LinearLayout>
    </LinearLayout>

    <!-- My Reviews section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Reviews"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#374151"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvNoPostsYet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="You haven't posted any reviews yet"
        android:textColor="#9ca3af"
        android:textSize="14sp"
        android:layout_marginTop="32dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMyPosts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="80dp"/>

</LinearLayout>
